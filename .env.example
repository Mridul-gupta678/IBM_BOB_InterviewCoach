# ============================================================
#  IBM Watsonx.ai — Interview Trainer Configuration
# ============================================================
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# ----------------------------------------------------------
# IBM Cloud / Watsonx Credentials
# ----------------------------------------------------------
IBM_API_KEY=your_ibm_cloud_api_key
WATSONX_PROJECT_ID=your_project_id
WATSONX_URL=https://au-syd.ml.cloud.ibm.com

# ----------------------------------------------------------
# Flask Settings
# ----------------------------------------------------------
FLASK_SECRET_KEY=change_this_to_a_long_random_string
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001

# ----------------------------------------------------------
# Model Settings
# ----------------------------------------------------------
# Recommended Granite models for interview coaching:
#   ibm/granite-3-8b-instruct   (fast, efficient — recommended)
#   ibm/granite-3-2b-instruct   (lightweight, very fast)
#   meta-llama/llama-3-3-70b-instruct  (highest quality, slower)
WATSONX_MODEL_ID=meta-llama/llama-3-3-70b-instruct
MAX_NEW_TOKENS=1200
TEMPERATURE=0.7
TOP_P=0.9

# ----------------------------------------------------------
# Fallback Providers Settings (Optional)
# ----------------------------------------------------------
# LLM_PROVIDER options: auto | watsonx | huggingface | demo
LLM_PROVIDER=auto

HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
